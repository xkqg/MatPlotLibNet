<Window x:Class="MatPlotLibNet.Samples.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mpl="clr-namespace:MatPlotLibNet.Wpf;assembly=MatPlotLibNet.Wpf"
        Title="MatPlotLibNet — WPF Sample" Height="620" Width="900">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="8" Grid.Row="0">
            <Button x:Name="LineButton"      Content="Line"      Margin="0,0,8,0" Padding="12,4" Click="OnLineClicked" />
            <Button x:Name="BarButton"       Content="Bar"       Margin="0,0,8,0" Padding="12,4" Click="OnBarClicked" />
            <Button x:Name="ScatterButton"   Content="Scatter"   Margin="0,0,8,0" Padding="12,4" Click="OnScatterClicked" />
            <Button x:Name="SurfaceButton"   Content="3D Surface" Margin="0,0,8,0" Padding="12,4" Click="OnSurfaceClicked" />
            <CheckBox x:Name="InteractiveToggle" Content="Interactive (pan / zoom / 3D rotate)"
                      VerticalAlignment="Center" Margin="16,0,0,0" IsChecked="True"
                      Checked="OnInteractiveChanged" Unchecked="OnInteractiveChanged" />
        </StackPanel>

        <mpl:MplChartControl x:Name="Chart" Grid.Row="1" IsInteractive="True" />
    </Grid>
</Window>
