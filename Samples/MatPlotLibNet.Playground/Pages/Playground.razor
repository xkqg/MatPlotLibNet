@page "/"
@using MatPlotLibNet
@using MatPlotLibNet.Models
@using MatPlotLibNet.Playground
@using MatPlotLibNet.Styling
@using MatPlotLibNet.Styling.ColorMaps
@inject IJSRuntime JS

<div class="playground-layout">
    <div class="panel panel-controls">
        <select class="example-select" @bind="_selectedExample" @bind:after="OnExampleChanged">
            @foreach (var example in PlaygroundExamples.Examples)
            {
                <option value="@example">@example.DisplayName()</option>
            }
        </select>

        <div class="section-title">Figure</div>

        <div class="param-group">
            <label>Title</label>
            <input type="text" @bind="_title" @bind:event="oninput" @bind:after="Rebuild" />
        </div>

        <div class="param-group">
            <label>Theme</label>
            @* Phase N.1: @bind-value carries the Theme INDEX into ThemeChoices, not a magic
               string name. OnThemeChanged resolves the index back to the typed Theme instance. *@
            <select @onchange="OnThemeChanged">
                <optgroup label="Light">
                    @for (int i = 0; i < LightThemeChoices.Length; i++)
                    {
                        var idx = i;
                        <option value="@idx" selected="@(ReferenceEquals(_theme, LightThemeChoices[idx].Theme))">@LightThemeChoices[idx].Label</option>
                    }
                </optgroup>
                <optgroup label="Dark">
                    @for (int i = 0; i < DarkThemeChoices.Length; i++)
                    {
                        var idx = i + LightThemeChoices.Length;
                        <option value="@idx" selected="@(ReferenceEquals(_theme, DarkThemeChoices[i].Theme))">@DarkThemeChoices[i].Label</option>
                    }
                </optgroup>
                <optgroup label="Accessibility">
                    @for (int i = 0; i < AccessibilityThemeChoices.Length; i++)
                    {
                        var idx = i + LightThemeChoices.Length + DarkThemeChoices.Length;
                        <option value="@idx" selected="@(ReferenceEquals(_theme, AccessibilityThemeChoices[i].Theme))">@AccessibilityThemeChoices[i].Label</option>
                    }
                </optgroup>
            </select>
        </div>

        @* Phase L.5 — Width/Height sliders removed. The SVG is responsive by
           default (Phase L.2: style="max-width:100%;height:auto"), so the chart
           fills the preview pane automatically and resizing the window resizes
           the chart. The intrinsic natural aspect stays 16:9 (800×450) for the
           viewBox and the copyable code snippet's .WithSize(...). *@

        @* Phase P — "Tight layout" checkbox removed. The toggle had no visible
           effect in the current playground layout because the responsive SVG
           stretches the figure to the pane regardless of internal margins.
           Tight layout stays ALWAYS-ON internally (_tightLayout default = true);
           per the "functional-or-remove" rule, a non-functional UI control
           gets removed rather than shown as a placeholder. *@

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_browserInteraction" @bind:after="Rebuild" /> Browser-interactive (pan/zoom/tooltips)
            </label>
            <div class="hint">
                <strong>2D charts:</strong> scroll to zoom, drag to pan, double-click or <kbd>Home</kbd> to reset. Hold <kbd>x</kbd> / <kbd>y</kbd> while dragging to lock the pan axis.<br/>
                <strong>3D charts:</strong> drag to rotate (full-axes drag = 180°, matplotlib parity), scroll to zoom camera distance, arrow keys for ±5° rotation, <kbd>+</kbd>/<kbd>-</kbd> for distance, <kbd>Home</kbd> to reset.<br/>
                <strong>Treemap:</strong> every depth (incl. iPhone / Galaxy / Pixel under Phones) is visible on first paint — z-order means the deepest label wins in any region. Click a parent tile to <em>collapse</em> its subtree (focus); click again to restore. Multiple subtrees can be collapsed independently (v1.7.2 Phase W).<br/>
                <strong>Legend:</strong> click an item to toggle the series, press-and-hold an item to drag the legend to a new spot.<br/>
                <strong>Sankey:</strong> hover a node to emphasise its upstream + downstream flow (<kbd>Tab</kbd> for keyboard focus).<br/>
                <strong>Touch:</strong> pinch-to-zoom on 2D, drag to rotate on 3D.<br/>
                <em>Open in a new tab for the full experience. Full keyboard reference in the <a href="https://github.com/xkqg/MatPlotLibNet/wiki/Keyboard-Shortcuts">wiki</a>.</em>
            </div>
        </div>

        <div class="section-title">Axes</div>

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_showLegend" @bind:after="Rebuild" /> Show legend
            </label>
        </div>

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_showGrid" @bind:after="Rebuild" /> Show grid
            </label>
        </div>

        @* Phase P — spine + tight-margin toggles are 2D-cartesian concepts; hide
           them for 3D / polar / radar / pie / sankey / treemap where they have
           no visible effect. *@
        @if (PlaygroundExamples.HasCartesianSpines(_selectedExample))
        {
            <div class="param-group">
                <label>
                    <input type="checkbox" @bind="_hideTopSpine" @bind:after="Rebuild" /> Hide top spine
                </label>
            </div>

            <div class="param-group">
                <label>
                    <input type="checkbox" @bind="_hideRightSpine" @bind:after="Rebuild" /> Hide right spine
                </label>
            </div>

            <div class="param-group">
                <label>
                    <input type="checkbox" @bind="_tightMargins" @bind:after="Rebuild" /> Tight margins (data touches spines)
                </label>
            </div>
        }

        @if (PlaygroundExamples.SupportsLineControls(_selectedExample) || PlaygroundExamples.SupportsMarkerControls(_selectedExample))
        {
            <div class="section-title">Series</div>

            @if (PlaygroundExamples.SupportsLineControls(_selectedExample))
            {
                <div class="param-group">
                    <label>Line style</label>
                    <select @bind="_lineStyle" @bind:after="Rebuild">
                        @foreach (var ls in Enum.GetValues<LineStyle>())
                        {
                            if (ls == LineStyle.None) continue;
                            <option value="@ls">@ls</option>
                        }
                    </select>
                </div>

                <div class="param-group">
                    <label>Line width: @_lineWidth</label>
                    <input type="range" min="0.5" max="5" step="0.5" @bind="_lineWidth" @bind:event="oninput" @bind:after="Rebuild" />
                </div>
            }

            @if (PlaygroundExamples.SupportsMarkerControls(_selectedExample))
            {
                var isScatter = _selectedExample == PlaygroundExample.ScatterPlot;
                <div class="param-group">
                    <label>Marker</label>
                    <select @bind="_marker" @bind:after="Rebuild">
                        @foreach (var m in Enum.GetValues<MarkerStyle>())
                        {
                            if (isScatter && m == MarkerStyle.None) continue;
                            <option value="@m">@m</option>
                        }
                    </select>
                </div>

                @if (isScatter || _marker != MarkerStyle.None)
                {
                    <div class="param-group">
                        <label>Marker size: @_markerSize</label>
                        <input type="range" min="2" max="16" step="1" @bind="_markerSize" @bind:event="oninput" @bind:after="Rebuild" />
                    </div>
                }
            }
        }

        @if (PlaygroundExamples.SupportsColormap(_selectedExample))
        {
            <div class="section-title">Colormap</div>

            <div class="param-group">
                <label>Colormap</label>
                <select @onchange="OnColorMapChanged">
                    @for (int i = 0; i < ColorMapChoices.Length; i++)
                    {
                        var idx = i;
                        <option value="@idx" selected="@(ReferenceEquals(_colorMap, ColorMapChoices[idx]))">@ColorMapChoices[idx].Name</option>
                    }
                </select>
            </div>

            <div class="param-group">
                <label>
                    <input type="checkbox" @bind="_showColorBar" @bind:after="Rebuild" /> Show colorbar
                </label>
            </div>
        }

        <div class="section-title">Code</div>
        <div class="code-block">
            <button class="copy-btn" @onclick="CopyCode">Copy</button>@_code
        </div>
    </div>

    <div class="panel panel-preview">
        <div class="chart-toolbar">
            <button class="primary" @onclick="OpenInNewTab" title="Open the SVG in a new tab so you can pan/zoom/hover for real">↗ Open in new tab</button>
            <button @onclick="DownloadSvg" title="Save the rendered chart as an SVG file">⬇ SVG</button>
            <button @onclick="DownloadPng" title="Rasterise the chart to PNG and download">⬇ PNG</button>
            <button @onclick="DownloadCode" title="Save the C# code to a .cs file you can run">⬇ Code</button>
        </div>
        @* Preview pane.
           When BrowserInteraction is OFF, we inline the SVG via MarkupString -- this
           is fast and lets CSS scale the SVG to fit. When BrowserInteraction is ON,
           we wrap the SVG in <iframe srcdoc="..."> instead because browsers DO NOT
           execute <script> tags inserted via innerHTML (a documented HTML5 security
           rule). The iframe gets a fresh document parser, so the embedded pan/zoom
           /tooltip /legend-toggle /highlight /selection scripts actually run. *@
        @if (_browserInteraction)
        {
            <div class="chart-preview">
                <iframe class="interactive-frame" srcdoc="@SvgIframeWrapper.WrapForIframe(_svg)" title="Interactive chart preview"></iframe>
            </div>
        }
        else
        {
            <div class="chart-preview">
                @((MarkupString)_svg)
            </div>
        }
    </div>
</div>

@code {
    // Phase L.5: the Width/Height sliders were removed — the SVG is responsive so
    // the chart fills whatever pane it lives in. These constants drive only the
    // intrinsic viewBox aspect + the `.WithSize(...)` line in the code snippet.
    private const int IntrinsicWidth  = 800;
    private const int IntrinsicHeight = 450;

    // Phase N.1 + Phase P fix — typed choice arrays paired with display labels.
    // Phase N.1 introduced Theme instances keyed by index. Phase P (2026-04-18)
    // discovered Theme.Name returns the same base string for all community-derived
    // themes (e.g. Theme.Solarize.Name == "custom-default" because the factory
    // creates solarize/grayscale/paper/… from the same base). Using .Name as the
    // dropdown label therefore produced 12 duplicate "custom-default" entries
    // (light) and 8 "custom-dark" entries (dark). The label must be sourced
    // independently — same pattern as PlaygroundExample's [Description] attribute.
    private static readonly (Theme Theme, string Label)[] LightThemeChoices =
    {
        (Theme.Default,          "Default"),
        (Theme.Seaborn,           "Seaborn"),
        (Theme.Ggplot,            "Ggplot"),
        (Theme.FiveThirtyEight,   "FiveThirtyEight"),
        (Theme.Bmh,               "Bmh"),
        (Theme.Solarize,          "Solarize"),
        (Theme.Grayscale,         "Grayscale"),
        (Theme.Paper,             "Paper"),
        (Theme.Presentation,      "Presentation"),
        (Theme.Poster,            "Poster"),
        (Theme.GitHub,            "GitHub"),
        (Theme.Minimal,           "Minimal"),
        (Theme.Retro,             "Retro"),
        (Theme.MatplotlibClassic, "MatplotlibClassic"),
        (Theme.MatplotlibV2,      "MatplotlibV2"),
    };

    private static readonly (Theme Theme, string Label)[] DarkThemeChoices =
    {
        (Theme.Dark,       "Dark"),
        (Theme.Cyberpunk,  "Cyberpunk"),
        (Theme.Nord,       "Nord"),
        (Theme.Dracula,    "Dracula"),
        (Theme.Monokai,    "Monokai"),
        (Theme.Catppuccin, "Catppuccin"),
        (Theme.Gruvbox,    "Gruvbox"),
        (Theme.OneDark,    "OneDark"),
        (Theme.Neon,       "Neon"),
    };

    private static readonly (Theme Theme, string Label)[] AccessibilityThemeChoices =
    {
        (Theme.ColorBlindSafe, "ColorBlindSafe"),
        (Theme.HighContrast,   "HighContrast"),
    };

    private (Theme Theme, string Label)[] AllThemeChoices =>
        LightThemeChoices.Concat(DarkThemeChoices).Concat(AccessibilityThemeChoices).ToArray();

    private static readonly IColorMap[] ColorMapChoices =
    {
        ColorMaps.Viridis, ColorMaps.Plasma, ColorMaps.Inferno, ColorMaps.Magma,
        ColorMaps.Turbo, ColorMaps.Coolwarm,
        MatPlotLibNet.Styling.ColorMaps.SequentialColorMaps.Greys,
        MatPlotLibNet.Styling.ColorMaps.SequentialColorMaps.Hot,
        ColorMaps.Jet,
    };

    private PlaygroundExample _selectedExample = PlaygroundExample.LineChart;
    private string            _title           = PlaygroundExample.LineChart.DisplayName();
    private Theme             _theme           = Theme.Default;
    private bool              _tightLayout     = true;    // Phase P: on by default so charts fill the pane without the matplotlib-style whitespace frame
    private bool              _browserInteraction = true;   // Phase P: on by default so pan/zoom works immediately
    private bool              _showLegend      = true;
    private bool              _showGrid        = true;
    private bool              _hideTopSpine;
    private bool              _hideRightSpine;
    private bool              _tightMargins;
    private LineStyle         _lineStyle       = LineStyle.Solid;
    private double            _lineWidth       = 1.5;
    private MarkerStyle       _marker          = MarkerStyle.None;
    private int               _markerSize      = 6;
    private IColorMap         _colorMap        = ColorMaps.Viridis;
    private bool              _showColorBar    = true;

    private string _svg  = "";
    private string _code = "";

    protected override void OnInitialized() => Rebuild();

    private PlaygroundOptions CurrentOptions => new()
    {
        Title              = _title,
        Theme              = _theme,
        Width              = IntrinsicWidth,
        Height             = IntrinsicHeight,
        TightLayout        = _tightLayout,
        BrowserInteraction = _browserInteraction,
        ShowLegend         = _showLegend,
        ShowGrid           = _showGrid,
        HideTopSpine       = _hideTopSpine,
        HideRightSpine     = _hideRightSpine,
        TightMargins       = _tightMargins,
        LineStyle          = _lineStyle,
        LineWidth          = _lineWidth,
        Marker             = _marker,
        MarkerSize         = _markerSize,
        ColorMap           = _colorMap,
        ShowColorBar       = _showColorBar,
    };

    private void OnExampleChanged()
    {
        _title = _selectedExample.DisplayName();
        Rebuild();
    }

    private void OnThemeChanged(ChangeEventArgs e)
    {
        _theme = PlaygroundController.SelectThemeByIndex(e.Value?.ToString(), AllThemeChoices) ?? _theme;
        Rebuild();
    }

    private void OnColorMapChanged(ChangeEventArgs e)
    {
        _colorMap = PlaygroundController.SelectColorMapByIndex(e.Value?.ToString(), ColorMapChoices) ?? _colorMap;
        Rebuild();
    }

    private void Rebuild()
    {
        PlaygroundController.TryBuild(_selectedExample, CurrentOptions, out _svg, out _code, out _);
    }

    private async Task CopyCode()       => await JS.InvokeVoidAsync("copyToClipboard", _code);
    // Phase M.1 — wrap the SVG in a full HTML document before opening so the
    // embedded pan/zoom/tooltip scripts execute and the chart stretches to fill
    // the viewport (CSS from SvgIframeWrapper). Bare-SVG blob (image/svg+xml)
    // landed in a standalone-SVG context where neither worked. Reuses the same
    // wrapper used by the iframe preview (Phase L.7).
    private async Task OpenInNewTab()   => await JS.InvokeVoidAsync("openInNewTab", SvgIframeWrapper.WrapForIframe(_svg));
    private async Task DownloadSvg()    => await JS.InvokeVoidAsync("downloadFile", _svg, FileName(".svg"), "image/svg+xml");
    private async Task DownloadPng()    => await JS.InvokeVoidAsync("downloadPng", _svg, FileName(".png"));
    private async Task DownloadCode()   => await JS.InvokeVoidAsync("downloadFile", _code, FileName(".cs"), "text/plain");

    private string FileName(string ext)
    {
        var name = _selectedExample.ToString().ToLowerInvariant();
        return $"matplotlibnet_{name}{ext}";
    }
}
