@page "/"
@using MatPlotLibNet
@using MatPlotLibNet.Models
@using MatPlotLibNet.Playground
@inject IJSRuntime JS

<div class="playground-layout">
    <div class="panel panel-controls">
        <select class="example-select" @onchange="OnExampleChanged">
            @foreach (var name in PlaygroundExamples.Names)
            {
                <option value="@name" selected="@(_selectedExample == name)">@name</option>
            }
        </select>

        <div class="section-title">Figure</div>

        <div class="param-group">
            <label>Title</label>
            <input type="text" @bind="_title" @bind:event="oninput" @bind:after="Rebuild" />
        </div>

        <div class="param-group">
            <label>Theme</label>
            <select @bind="_themeName" @bind:after="Rebuild">
                <optgroup label="Light">
                    <option>Default</option>
                    <option>Seaborn</option>
                    <option>Ggplot</option>
                    <option>FiveThirtyEight</option>
                    <option>Bmh</option>
                    <option>Solarize</option>
                    <option>Grayscale</option>
                    <option>Paper</option>
                    <option>Presentation</option>
                    <option>Poster</option>
                    <option>GitHub</option>
                    <option>Minimal</option>
                    <option>Retro</option>
                    <option>MatplotlibClassic</option>
                    <option>MatplotlibV2</option>
                </optgroup>
                <optgroup label="Dark">
                    <option>Dark</option>
                    <option>Cyberpunk</option>
                    <option>Nord</option>
                    <option>Dracula</option>
                    <option>Monokai</option>
                    <option>Catppuccin</option>
                    <option>Gruvbox</option>
                    <option>OneDark</option>
                    <option>Neon</option>
                </optgroup>
                <optgroup label="Accessibility">
                    <option>ColorBlindSafe</option>
                    <option>HighContrast</option>
                </optgroup>
            </select>
        </div>

        @* Phase L.5 — Width/Height sliders removed. The SVG is responsive by
           default (Phase L.2: style="max-width:100%;height:auto"), so the chart
           fills the preview pane automatically and resizing the window resizes
           the chart. The intrinsic natural aspect stays 16:9 (800×450) for the
           viewBox and the copyable code snippet's .WithSize(...). *@

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_tightLayout" @bind:after="Rebuild" /> Tight layout
            </label>
        </div>

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_browserInteraction" @bind:after="Rebuild" /> Browser-interactive (pan/zoom/tooltips)
            </label>
            <div class="hint">
                <strong>2D charts:</strong> scroll to zoom, drag to pan, double-click or <kbd>Home</kbd> to reset. Hold <kbd>x</kbd> / <kbd>y</kbd> while dragging to lock the pan axis.<br/>
                <strong>3D charts:</strong> drag to rotate (full-axes drag = 180°, matplotlib parity), scroll to zoom camera distance, arrow keys for ±5° rotation, <kbd>+</kbd>/<kbd>-</kbd> for distance, <kbd>Home</kbd> to reset.<br/>
                <strong>Treemap:</strong> click a tile to drill (animated sliding zoom), <kbd>Esc</kbd> to pop back.<br/>
                <strong>Sankey:</strong> hover a node to emphasise its upstream + downstream flow (<kbd>Tab</kbd> for keyboard focus).<br/>
                <strong>Touch:</strong> pinch-to-zoom on 2D, drag to rotate on 3D.<br/>
                <em>Open in a new tab for the full experience. Full keyboard reference in the <a href="https://github.com/xkqg/MatPlotLibNet/wiki/Keyboard-Shortcuts">wiki</a>.</em>
            </div>
        </div>

        <div class="section-title">Axes</div>

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_showLegend" @bind:after="Rebuild" /> Show legend
            </label>
        </div>

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_showGrid" @bind:after="Rebuild" /> Show grid
            </label>
        </div>

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_hideTopSpine" @bind:after="Rebuild" /> Hide top spine
            </label>
        </div>

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_hideRightSpine" @bind:after="Rebuild" /> Hide right spine
            </label>
        </div>

        <div class="param-group">
            <label>
                <input type="checkbox" @bind="_tightMargins" @bind:after="Rebuild" /> Tight margins (data touches spines)
            </label>
        </div>

        @if (PlaygroundExamples.SupportsLineControls(_selectedExample) || PlaygroundExamples.SupportsMarkerControls(_selectedExample))
        {
            <div class="section-title">Series</div>

            @if (PlaygroundExamples.SupportsLineControls(_selectedExample))
            {
                <div class="param-group">
                    <label>Line style</label>
                    <select @bind="_lineStyle" @bind:after="Rebuild">
                        <option>Solid</option>
                        <option>Dashed</option>
                        <option>Dotted</option>
                        <option>DashDot</option>
                    </select>
                </div>

                <div class="param-group">
                    <label>Line width: @_lineWidth</label>
                    <input type="range" min="0.5" max="5" step="0.5" @bind="_lineWidth" @bind:event="oninput" @bind:after="Rebuild" />
                </div>
            }

            @if (PlaygroundExamples.SupportsMarkerControls(_selectedExample))
            {
                var isScatter = _selectedExample == "Scatter Plot";
                <div class="param-group">
                    <label>Marker</label>
                    <select @bind="_markerStyle" @bind:after="Rebuild">
                        @if (!isScatter) { <option>None</option> }
                        <option>Circle</option>
                        <option>Square</option>
                        <option>Triangle</option>
                        <option>Diamond</option>
                        <option>Star</option>
                        <option>Cross</option>
                        <option>Plus</option>
                    </select>
                </div>

                @if (isScatter || _markerStyle != "None")
                {
                    <div class="param-group">
                        <label>Marker size: @_markerSize</label>
                        <input type="range" min="2" max="16" step="1" @bind="_markerSize" @bind:event="oninput" @bind:after="Rebuild" />
                    </div>
                }
            }
        }

        @if (PlaygroundExamples.SupportsColormap(_selectedExample))
        {
            <div class="section-title">Colormap</div>

            <div class="param-group">
                <label>Colormap</label>
                <select @bind="_colorMap" @bind:after="Rebuild">
                    <option>viridis</option>
                    <option>plasma</option>
                    <option>inferno</option>
                    <option>magma</option>
                    <option>turbo</option>
                    <option>coolwarm</option>
                    <option>greys</option>
                    <option>hot</option>
                    <option>jet</option>
                </select>
            </div>

            <div class="param-group">
                <label>
                    <input type="checkbox" @bind="_showColorBar" @bind:after="Rebuild" /> Show colorbar
                </label>
            </div>
        }

        <div class="section-title">Code</div>
        <div class="code-block">
            <button class="copy-btn" @onclick="CopyCode">Copy</button>@_code
        </div>
    </div>

    <div class="panel panel-preview">
        <div class="chart-toolbar">
            <button class="primary" @onclick="OpenInNewTab" title="Open the SVG in a new tab so you can pan/zoom/hover for real">↗ Open in new tab</button>
            <button @onclick="DownloadSvg" title="Save the rendered chart as an SVG file">⬇ SVG</button>
            <button @onclick="DownloadPng" title="Rasterise the chart to PNG and download">⬇ PNG</button>
            <button @onclick="DownloadCode" title="Save the C# code to a .cs file you can run">⬇ Code</button>
        </div>
        @* Preview pane.
           When BrowserInteraction is OFF, we inline the SVG via MarkupString -- this
           is fast and lets CSS scale the SVG to fit. When BrowserInteraction is ON,
           we wrap the SVG in <iframe srcdoc="..."> instead because browsers DO NOT
           execute <script> tags inserted via innerHTML (a documented HTML5 security
           rule). The iframe gets a fresh document parser, so the embedded pan/zoom
           /tooltip /legend-toggle /highlight /selection scripts actually run. *@
        @if (_browserInteraction)
        {
            <div class="chart-preview">
                <iframe class="interactive-frame" srcdoc="@SvgIframeWrapper.WrapForIframe(_svg)" title="Interactive chart preview"></iframe>
            </div>
        }
        else
        {
            <div class="chart-preview">
                @((MarkupString)_svg)
            </div>
        }
    </div>
</div>

@code {
    // Phase L.5: the Width/Height sliders were removed — the SVG is responsive so
    // the chart fills whatever pane it lives in. These constants drive only the
    // intrinsic viewBox aspect + the `.WithSize(...)` line in the code snippet.
    private const int IntrinsicWidth  = 800;
    private const int IntrinsicHeight = 450;

    private string _selectedExample = "Line Chart";
    private string _title           = "Line Chart";
    private string _themeName       = "Default";
    private bool   _tightLayout;
    private bool   _browserInteraction;
    private bool   _showLegend      = true;
    private bool   _showGrid        = true;
    private bool   _hideTopSpine;
    private bool   _hideRightSpine;
    private bool   _tightMargins;
    private string _lineStyle       = "Solid";
    private double _lineWidth       = 1.5;
    private string _markerStyle     = "None";
    private int    _markerSize      = 6;
    private string _colorMap        = "viridis";
    private bool   _showColorBar    = true;

    private string _svg  = "";
    private string _code = "";

    protected override void OnInitialized() => Rebuild();

    private PlaygroundOptions CurrentOptions => new()
    {
        Title              = _title,
        ThemeName          = _themeName,
        Width              = IntrinsicWidth,
        Height             = IntrinsicHeight,
        TightLayout        = _tightLayout,
        BrowserInteraction = _browserInteraction,
        ShowLegend         = _showLegend,
        ShowGrid           = _showGrid,
        HideTopSpine       = _hideTopSpine,
        HideRightSpine     = _hideRightSpine,
        TightMargins       = _tightMargins,
        LineStyle          = _lineStyle,
        LineWidth          = _lineWidth,
        MarkerStyle        = _markerStyle,
        MarkerSize         = _markerSize,
        ColorMap           = _colorMap,
        ShowColorBar       = _showColorBar,
    };

    private void OnExampleChanged(ChangeEventArgs e)
    {
        _selectedExample = e.Value?.ToString() ?? "Line Chart";
        _title = _selectedExample;
        Rebuild();
    }

    private void Rebuild()
    {
        try
        {
            var (figure, code) = PlaygroundExamples.Build(_selectedExample, CurrentOptions);
            _svg  = figure.ToSvg();
            _code = code;
        }
        catch (Exception ex)
        {
            _svg = "<p style='color:red;padding:20px'>" + ex.Message + "</p>";
        }
    }

    private async Task CopyCode()       => await JS.InvokeVoidAsync("copyToClipboard", _code);
    // Phase M.1 — wrap the SVG in a full HTML document before opening so the
    // embedded pan/zoom/tooltip scripts execute and the chart stretches to fill
    // the viewport (CSS from SvgIframeWrapper). Bare-SVG blob (image/svg+xml)
    // landed in a standalone-SVG context where neither worked. Reuses the same
    // wrapper used by the iframe preview (Phase L.7).
    private async Task OpenInNewTab()   => await JS.InvokeVoidAsync("openInNewTab", SvgIframeWrapper.WrapForIframe(_svg));
    private async Task DownloadSvg()    => await JS.InvokeVoidAsync("downloadFile", _svg, FileName(".svg"), "image/svg+xml");
    private async Task DownloadPng()    => await JS.InvokeVoidAsync("downloadPng", _svg, FileName(".png"));
    private async Task DownloadCode()   => await JS.InvokeVoidAsync("downloadFile", _code, FileName(".cs"), "text/plain");

    private string FileName(string ext)
    {
        var name = _selectedExample.ToLowerInvariant().Replace(' ', '_').Replace('-', '_');
        return $"matplotlibnet_{name}{ext}";
    }
}
