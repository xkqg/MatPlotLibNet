<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Targets Windows (WinUI 3) + all Uno-supported platforms.
         SKCanvasElement is in SkiaSharp.Views.Uno.WinUI and resolves identically on all targets. -->
    <TargetFrameworks>net10.0-android;net10.0-ios;net10.0-maccatalyst;net10.0-windows10.0.19041.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>1.3.0</Version>
    <PackageId>MatPlotLibNet.Uno</PackageId>
    <Description>Uno Platform (WinUI 3) chart control for MatPlotLibNet. Renders charts natively via SkiaSharp across Windows, Android, iOS, and macCatalyst with optional pan/zoom/reset interaction.</Description>
    <PackageTags>charting;plotting;charts;uno;winui;skiasharp;cross-platform;interactive</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <!-- Uno.WinUI ships legacy win10-* RIDs; disable the .NET 10 RID graph to allow restore -->
    <UseRidGraph>false</UseRidGraph>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'ios'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'maccatalyst'">15.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">21.0</SupportedOSPlatformVersion>
    <SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'windows'">10.0.19041.0</SupportedOSPlatformVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- Uno.WinUI: WinUI 3 XAML runtime on all supported platforms -->
    <PackageReference Include="Uno.WinUI" Version="5.*" />
    <!-- SkiaSharp.Views.Uno.WinUI: provides SKCanvasElement -->
    <PackageReference Include="SkiaSharp.Views.Uno.WinUI" Version="3.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MatPlotLibNet.Skia\MatPlotLibNet.Skia.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
