<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- CI-safe: target Windows (WinUI 3) only. SKCanvasElement is source-generated by the
         Uno build pipeline and only resolves when the Uno workload is installed; the
         SkiaSharp.Views.Uno.WinUI package ships an empty _._  marker on non-Windows TFMs.
         Cross-platform consumers (Android/iOS/macCatalyst) can add additional TFMs and build
         from source with the Uno workload installed locally. -->
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>1.3.0</Version>
    <PackageId>MatPlotLibNet.Uno</PackageId>
    <Description>Uno Platform (WinUI 3) chart control for MatPlotLibNet. Renders charts natively via SkiaSharp with optional pan/zoom/reset interaction. Windows TFM out of the box; add Android/iOS/macCatalyst TFMs when building from source with the Uno workload.</Description>
    <PackageTags>charting;plotting;charts;uno;winui;skiasharp;cross-platform;interactive</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <!-- Uno.WinUI transitively pulls WindowsAppSDK which injects legacy win10-* RIDs via
         MrtCore.PriGen.targets. Override with explicit RIDs that .NET 10 recognises. -->
    <RuntimeIdentifiers>win-x64;win-x86;win-arm64</RuntimeIdentifiers>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
  </PropertyGroup>

  <ItemGroup>
    <!-- Uno.WinUI: WinUI 3 XAML runtime on all supported platforms -->
    <PackageReference Include="Uno.WinUI" Version="5.*" />
    <!-- SkiaSharp.Views.Uno.WinUI: provides SKCanvasElement -->
    <PackageReference Include="SkiaSharp.Views.Uno.WinUI" Version="3.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MatPlotLibNet.Skia\MatPlotLibNet.Skia.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
