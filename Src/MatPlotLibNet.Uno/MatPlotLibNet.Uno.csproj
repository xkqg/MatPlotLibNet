<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- net8.0 targets the Uno Platform Skia desktop backend. SKCanvasElement
         (from Uno.WinUI.Graphics2DSK) is only available on the Skia rendering path.
         Builds on all platforms (CLI + VS). -->
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>1.12.0</Version>
    <PackageId>MatPlotLibNet.Uno</PackageId>
    <Description>Uno Platform chart control for MatPlotLibNet. Renders charts natively via SkiaSharp with optional pan/zoom/reset interaction.</Description>
    <PackageTags>charting;plotting;charts;uno;winui;skiasharp;cross-platform;interactive</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <WindowsAppSDKSelfContained>false</WindowsAppSDKSelfContained>
    <WindowsPackageType>None</WindowsPackageType>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Uno.WinUI" Version="5.6.99" />
    <PackageReference Include="Uno.WinUI.Graphics2DSK" Version="5.6.99" />
    <!-- Pinned: SkiaSharp.Views.Uno.WinUI 3.119.4+ DROPPED net8.0 (supports net9/net10 only). This project's
         Uno Skia desktop backend targets net8.0, so the floating "3.*" broke restore with NU1202. 3.119.2 is the
         last 3.x that still ships a net8.0 asset. Revisit when this project moves off net8.0. -->
    <PackageReference Include="SkiaSharp.Views.Uno.WinUI" Version="3.119.2" />
    <!-- Suppress ALL WindowsAppSDK sub-package build targets. On net8.0 (Skia backend)
         these targets assume a Windows TFM and crash on empty TargetPlatformVersion.
         Uno handles platform abstraction â€” WindowsAppSDK targets are only needed for native WinUI. -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
    <PackageReference Include="Microsoft.WindowsAppSDK.Base" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
    <PackageReference Include="Microsoft.WindowsAppSDK.Foundation" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
    <PackageReference Include="Microsoft.WindowsAppSDK.InteractiveExperiences" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
    <PackageReference Include="Microsoft.WindowsAppSDK.WinUI" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
    <PackageReference Include="Microsoft.WindowsAppSDK.Widgets" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
    <PackageReference Include="Microsoft.WindowsAppSDK.Runtime" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
    <PackageReference Include="Microsoft.WindowsAppSDK.ML" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
    <PackageReference Include="Microsoft.WindowsAppSDK.DWrite" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
    <PackageReference Include="Microsoft.WindowsAppSDK.AI" Version="*" ExcludeAssets="build;buildTransitive" PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\MatPlotLibNet.Skia\MatPlotLibNet.Skia.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
