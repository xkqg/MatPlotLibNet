@namespace MatPlotLibNet.Blazor

@implements IAsyncDisposable

<div class="mpl-chart mpl-live @CssClass">
    @((MarkupString)_svgContent)
</div>

@code {
    [Parameter, EditorRequired] public string ChartId { get; set; } = default!;
    [Parameter] public string HubUrl { get; set; } = "/charts-hub";
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public Figure? InitialFigure { get; set; }
    /// <summary>Optional subscription client — exposed so tests can inject a mock
    /// and so host apps can share one connection across components. When null
    /// (default), the component creates its own <see cref="ChartSubscriptionClient"/>.
    /// Phase J.1 of v1.7.2 follow-on plan.</summary>
    [Parameter] public IChartSubscriptionClient? Client { get; set; }

    private IChartSubscriptionClient _client = default!;
    private string _svgContent = string.Empty;

    protected override void OnInitialized()
    {
        _client = Client ?? new ChartSubscriptionClient();
    }

    protected override void OnParametersSet()
    {
        if (InitialFigure is not null && string.IsNullOrEmpty(_svgContent))
            _svgContent = ChartServices.SvgRenderer.Render(InitialFigure);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        _client.OnSvgUpdated((id, svg) =>
        {
            if (id == ChartId)
            {
                _svgContent = svg;
                InvokeAsync(StateHasChanged);
            }
            return Task.CompletedTask;
        });

        _client.OnChartUpdated((id, json) =>
        {
            if (id == ChartId)
            {
                var figure = ChartServices.Serializer.FromJson(json);
                _svgContent = ChartServices.SvgRenderer.Render(figure);
                InvokeAsync(StateHasChanged);
            }
            return Task.CompletedTask;
        });

        await _client.ConnectAsync(HubUrl);
        await _client.SubscribeAsync(ChartId);
    }

    public async ValueTask DisposeAsync()
    {
        await _client.DisposeAsync();
    }
}
