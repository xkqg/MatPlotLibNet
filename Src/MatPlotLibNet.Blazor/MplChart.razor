@namespace MatPlotLibNet.Blazor

@if (DisplayMode == DisplayMode.Popup)
{
    <div class="mpl-chart mpl-popup @CssClass">
        @if (Figure is not null)
        {
            @((MarkupString)_svgContent)
        }
        @if (!string.IsNullOrEmpty(PopupUrl))
        {
            <a class="mpl-popup-link" href="@PopupUrl" target="_blank" rel="noopener">Open in new tab</a>
        }
    </div>
}
else if (DisplayMode == DisplayMode.Expandable)
{
    <div class="mpl-chart mpl-expandable @(_expanded ? "mpl-expanded" : "") @CssClass">
        <button class="mpl-expand-btn" @onclick="ToggleExpand">@(_expanded ? "Close" : "Expand")</button>
        @if (Figure is not null)
        {
            @((MarkupString)_svgContent)
        }
    </div>
}
else
{
    <div class="mpl-chart @CssClass">
        @if (Figure is not null)
        {
            @((MarkupString)_svgContent)
        }
    </div>
}

@code {
    [Parameter] public Figure? Figure { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public DisplayMode DisplayMode { get; set; } = DisplayMode.Inline;
    [Parameter] public string? PopupUrl { get; set; }

    private string _svgContent = string.Empty;
    private bool _expanded;

    protected override void OnParametersSet()
    {
        _svgContent = Figure is not null ? ChartServices.SvgRenderer.Render(Figure) : string.Empty;
    }

    private void ToggleExpand()
    {
        _expanded = !_expanded;
    }
}
