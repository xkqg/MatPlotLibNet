<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="xunit.v3" Version="3.*" />
    <PackageReference Include="coverlet.msbuild" Version="6.*" PrivateAssets="all" />
    <!-- Jint hosts the embedded browser-interaction JS scripts inside test-process for
         behavioural assertions (Phase 1 of the v1.7.2 interaction-hardening plan).
         MIT-licensed, pure managed code — no native deps. -->
    <PackageReference Include="Jint" Version="4.*" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\Src\MatPlotLibNet\MatPlotLibNet.csproj" />
    <ProjectReference Include="..\..\Src\MatPlotLibNet.Geo\MatPlotLibNet.Geo.csproj" />
    <ProjectReference Include="..\..\Samples\MatPlotLibNet.Playground\MatPlotLibNet.Playground.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Xunit" />
  </ItemGroup>

</Project>