{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "Src/MatPlotLibNet/MatPlotLibNet.csproj",
            "Src/MatPlotLibNet.Skia/MatPlotLibNet.Skia.csproj",
            "Src/MatPlotLibNet.Blazor/MatPlotLibNet.Blazor.csproj",
            "Src/MatPlotLibNet.AspNetCore/MatPlotLibNet.AspNetCore.csproj",
            "Src/MatPlotLibNet.Interactive/MatPlotLibNet.Interactive.csproj",
            "Src/MatPlotLibNet.GraphQL/MatPlotLibNet.GraphQL.csproj",
            "Src/MatPlotLibNet.DataFrame/MatPlotLibNet.DataFrame.csproj",
            "Src/MatPlotLibNet.Avalonia/MatPlotLibNet.Avalonia.csproj",
            "Src/MatPlotLibNet.Geo/MatPlotLibNet.Geo.csproj",
            "Src/MatPlotLibNet.Notebooks/MatPlotLibNet.Notebooks.csproj",
            "Src/MatPlotLibNet.Uno/MatPlotLibNet.Uno.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "properties": {
        "TargetFramework": "net8.0"
      }
    },
    {
      "_comment": "WPF metadata block disabled — net8.0-windows can't build on the Linux CI runner without EnableWindowsTargeting=true. Re-enable in a follow-up that adds <EnableWindowsTargeting Condition=...> to MatPlotLibNet.Wpf.csproj OR runs a separate Windows job for WPF API ref generation.",
      "src": [
        {
          "files": [],
          "src": ".."
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "properties": {
        "TargetFramework": "net8.0"
      }
    }
  ],
  "build": {
    "content": [
      { "files": ["api/**.yml", "api/index.md"] },
      { "files": ["cookbook/**.md", "cookbook/toc.yml"] },
      { "files": ["toc.yml", "*.md"] }
    ],
    "resource": [
      { "files": ["images/**"] }
    ],
    "dest": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "MatPlotLibNet",
      "_appFooter": "MatPlotLibNet — matplotlib for .NET &bull; MIT License",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/xkqg/MatPlotLibNet",
        "branch": "main",
        "path": "docs"
      }
    }
  }
}
